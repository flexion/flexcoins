{
  "name": "Multi Upgrade Purchase Test",
  "description": "Test purchasing all upgrade types and verify currency deduction and derived values",
  "steps": [
    {"type": "wait", "seconds": 0.5, "comment": "Wait for game to stabilize"},
    {"type": "command", "name": "reset-session", "comment": "Reset to clean state"},
    {"type": "command", "name": "clear-coins", "comment": "Remove any falling coins"},
    {"type": "wait", "seconds": 0.2},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "add_currency", "args": [100000], "comment": "Give 100000 currency"},
    {"type": "wait", "seconds": 0.2},
    {"type": "assert", "node": "/root/GameManager", "property": "currency", "equals": 100000},
    {"type": "screenshot", "filename": "multi_01_start.png"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_cost", "args": ["spawn_rate"], "comment": "Check spawn_rate cost (should be 10)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_spawn_interval", "comment": "Check initial spawn interval (0.8s)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["spawn_rate"], "comment": "Buy spawn_rate level 1 (cost 10)"},
    {"type": "wait", "seconds": 0.3},
    {"type": "assert", "node": "/root/GameManager", "property": "currency", "equals": 99990, "comment": "100000 - 10 = 99990"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["spawn_rate"], "comment": "Verify level 1"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_spawn_interval", "comment": "Verify spawn interval decreased"},
    {"type": "screenshot", "filename": "multi_02_spawn_rate.png"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_cost", "args": ["coin_value"], "comment": "Check coin_value cost (should be 15)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_coin_value", "comment": "Check initial coin value (1)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["coin_value"], "comment": "Buy coin_value level 1 (cost 15)"},
    {"type": "wait", "seconds": 0.3},
    {"type": "assert", "node": "/root/GameManager", "property": "currency", "equals": 99975, "comment": "99990 - 15 = 99975"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["coin_value"], "comment": "Verify level 1"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_coin_value", "comment": "Verify coin value increased to 2"},
    {"type": "screenshot", "filename": "multi_03_coin_value.png"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_cost", "args": ["catcher_speed"], "comment": "Check catcher_speed cost (should be 10)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_catcher_speed", "comment": "Check initial catcher speed (600)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["catcher_speed"], "comment": "Buy catcher_speed level 1 (cost 10)"},
    {"type": "wait", "seconds": 0.3},
    {"type": "assert", "node": "/root/GameManager", "property": "currency", "equals": 99965, "comment": "99975 - 10 = 99965"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["catcher_speed"], "comment": "Verify level 1"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_catcher_speed", "comment": "Verify speed increased to 650"},
    {"type": "screenshot", "filename": "multi_04_catcher_speed.png"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_cost", "args": ["catcher_width"], "comment": "Check catcher_width cost (should be 20)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_catcher_width", "comment": "Check initial catcher width (100)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["catcher_width"], "comment": "Buy catcher_width level 1 (cost 20)"},
    {"type": "wait", "seconds": 0.3},
    {"type": "assert", "node": "/root/GameManager", "property": "currency", "equals": 99945, "comment": "99965 - 20 = 99945"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["catcher_width"], "comment": "Verify level 1"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_catcher_width", "comment": "Verify width increased to 115"},
    {"type": "screenshot", "filename": "multi_05_catcher_width.png"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_cost", "args": ["magnet"], "comment": "Check magnet cost (should be 25)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_magnet_radius", "comment": "Check initial magnet radius (0)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_magnet_strength", "comment": "Check initial magnet strength (0)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["magnet"], "comment": "Buy magnet level 1 (cost 25)"},
    {"type": "wait", "seconds": 0.3},
    {"type": "assert", "node": "/root/GameManager", "property": "currency", "equals": 99920, "comment": "99945 - 25 = 99920"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["magnet"], "comment": "Verify level 1"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_magnet_radius", "comment": "Verify radius increased to 110"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_magnet_strength", "comment": "Verify strength increased to 140"},
    {"type": "screenshot", "filename": "multi_06_magnet.png"},
    {"type": "command", "name": "get-state", "node_path": "/root/GameManager", "property": "currency", "comment": "Check remaining currency after all purchases"},
    {"type": "screenshot", "filename": "multi_07_final.png"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["spawn_rate"], "comment": "Verify all upgrades at level 1"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["coin_value"]},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["catcher_speed"]},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["catcher_width"]},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["magnet"]},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_earn_rate", "comment": "Check final earn rate"},
    {"type": "command", "name": "clear-coins"}
  ]
}
