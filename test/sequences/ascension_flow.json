{
  "name": "Ascension Flow Test",
  "description": "Verify ascension fails when ineligible, succeeds at level 15, resets state, and applies 1.5x multiplier",
  "steps": [
    {"type": "wait", "seconds": 0.5, "comment": "Wait for game to stabilize"},
    {"type": "command", "name": "reset-session", "comment": "Reset to clean state"},
    {"type": "command", "name": "clear-coins", "comment": "Remove any falling coins"},
    {"type": "wait", "seconds": 0.2},

    {"type": "assert", "node": "/root/GameManager", "property": "ascension_count", "equals": 0},

    {"type": "command", "name": "ascend", "comment": "Should FAIL — upgrades at level 0"},
    {"type": "assert", "node": "/root/GameManager", "property": "ascension_count", "equals": 0},
    {"type": "screenshot", "filename": "ascension_01_ineligible.png"},

    {"type": "command", "name": "set-upgrade-levels", "spawn_rate": 15, "coin_value": 15, "catcher_speed": 15, "catcher_width": 14, "comment": "One upgrade short"},
    {"type": "command", "name": "ascend", "comment": "Should FAIL — catcher_width only 14"},
    {"type": "assert", "node": "/root/GameManager", "property": "ascension_count", "equals": 0},

    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "add_currency", "args": [50000], "comment": "Give plenty of currency"},
    {"type": "command", "name": "set-upgrade-levels", "spawn_rate": 15, "coin_value": 15, "catcher_speed": 15, "catcher_width": 15, "comment": "Set all core upgrades to 15"},
    {"type": "wait", "seconds": 0.3},
    {"type": "screenshot", "filename": "ascension_02_ready.png"},

    {"type": "command", "name": "ascend", "comment": "Should SUCCEED — all core at 15"},
    {"type": "wait", "seconds": 1.0, "comment": "Wait for ascension animation"},

    {"type": "screenshot", "filename": "ascension_03_ascended.png"},
    {"type": "assert", "node": "/root/GameManager", "property": "ascension_count", "equals": 1},
    {"type": "assert", "node": "/root/GameManager", "property": "currency", "equals": 0},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["spawn_rate"], "comment": "Should return 0 after ascension reset"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["magnet"], "comment": "Should return 0 — magnet also resets"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_ascension_multiplier", "comment": "Should return 1.5"},

    {"type": "command", "name": "ascend", "comment": "Should FAIL — upgrades reset to 0"},
    {"type": "assert", "node": "/root/GameManager", "property": "ascension_count", "equals": 1},

    {"type": "screenshot", "filename": "ascension_04_final.png"},
    {"type": "command", "name": "clear-coins"}
  ]
}
