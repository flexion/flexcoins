{
  "name": "Combo Buildup Test",
  "description": "Test basic combo mechanics by collecting coins and verifying combo counter increases",
  "steps": [
    {"type": "wait", "seconds": 0.5, "comment": "Wait for game to stabilize"},
    {"type": "command", "name": "reset-session", "comment": "Reset to clean state"},
    {"type": "command", "name": "clear-coins", "comment": "Remove any falling coins"},
    {"type": "wait", "seconds": 0.2},
    {"type": "command", "name": "get-state", "node_path": "/root/GameManager", "property": "_combo_multiplier", "comment": "Verify initial combo is 1.0"},
    {"type": "assert", "node": "/root/GameManager", "property": "_combo_multiplier", "equals": 1.0},
    {"type": "screenshot", "filename": "combo_01_start.png"},
    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "SILVER", "comment": "Spawn coin 1"},
    {"type": "wait", "seconds": 0.3, "comment": "Wait for coin to fall and get collected"},
    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "SILVER", "comment": "Spawn coin 2"},
    {"type": "wait", "seconds": 0.3},
    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "SILVER", "comment": "Spawn coin 3"},
    {"type": "wait", "seconds": 0.3},
    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "SILVER", "comment": "Spawn coin 4"},
    {"type": "wait", "seconds": 0.3},
    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "SILVER", "comment": "Spawn coin 5"},
    {"type": "wait", "seconds": 0.3},
    {"type": "screenshot", "filename": "combo_02_five_coins.png"},
    {"type": "command", "name": "get-catcher-state", "comment": "Get catcher state including combo count"},
    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "SILVER", "comment": "Continue collecting"},
    {"type": "wait", "seconds": 0.3},
    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "SILVER"},
    {"type": "wait", "seconds": 0.3},
    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "SILVER"},
    {"type": "wait", "seconds": 0.3},
    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "SILVER"},
    {"type": "wait", "seconds": 0.3},
    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "SILVER"},
    {"type": "wait", "seconds": 0.3},
    {"type": "screenshot", "filename": "combo_03_ten_coins.png"},
    {"type": "command", "name": "get-catcher-state", "comment": "Check combo count increased to 10"},
    {"type": "command", "name": "spawn-coin", "coin_type": "SILVER", "x": 1500, "comment": "Spawn coin away from catcher to miss it"},
    {"type": "wait", "seconds": 2.0, "comment": "Wait for coin to fall past catcher"},
    {"type": "screenshot", "filename": "combo_04_after_miss.png"},
    {"type": "command", "name": "get-catcher-state", "comment": "Verify combo reset after miss"},
    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "SILVER", "comment": "Start new combo"},
    {"type": "wait", "seconds": 0.3},
    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "SILVER"},
    {"type": "wait", "seconds": 0.3},
    {"type": "screenshot", "filename": "combo_05_new_combo.png"},
    {"type": "command", "name": "get-catcher-state", "comment": "Verify new combo started from scratch"},
    {"type": "command", "name": "clear-coins"}
  ]
}
