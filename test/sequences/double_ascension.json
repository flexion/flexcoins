{
  "name": "Double Ascension Test",
  "description": "Complete two ascensions, assert multiplier stacks: 1.5x then 2.25x, verify coin value boosted",
  "steps": [
    {"type": "wait", "seconds": 0.5, "comment": "Wait for game to stabilize"},
    {"type": "command", "name": "reset-session", "comment": "Reset to clean state"},
    {"type": "command", "name": "clear-coins", "comment": "Remove any falling coins"},
    {"type": "wait", "seconds": 0.2},

    {"type": "assert", "node": "/root/GameManager", "property": "ascension_count", "equals": 0},
    {"type": "screenshot", "filename": "double_asc_01_start.png"},

    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "add_currency", "args": [100000], "comment": "Give plenty of currency"},
    {"type": "command", "name": "set-upgrade-levels", "spawn_rate": 15, "coin_value": 15, "catcher_speed": 15, "catcher_width": 15, "comment": "Set all core upgrades to 15"},
    {"type": "wait", "seconds": 0.3},

    {"type": "command", "name": "ascend", "comment": "First ascension"},
    {"type": "wait", "seconds": 1.0, "comment": "Wait for ascension animation"},

    {"type": "screenshot", "filename": "double_asc_02_first_ascension.png"},
    {"type": "assert", "node": "/root/GameManager", "property": "ascension_count", "equals": 1},
    {"type": "assert", "node": "/root/GameManager", "property": "currency", "equals": 0},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_ascension_multiplier", "comment": "Should be 1.5"},

    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "add_currency", "args": [100000], "comment": "Give currency for second ascension"},
    {"type": "command", "name": "set-upgrade-levels", "spawn_rate": 15, "coin_value": 15, "catcher_speed": 15, "catcher_width": 15, "comment": "Set all core upgrades to 15 again"},
    {"type": "wait", "seconds": 0.3},

    {"type": "command", "name": "ascend", "comment": "Second ascension"},
    {"type": "wait", "seconds": 1.0, "comment": "Wait for ascension animation"},

    {"type": "screenshot", "filename": "double_asc_03_second_ascension.png"},
    {"type": "assert", "node": "/root/GameManager", "property": "ascension_count", "equals": 2},
    {"type": "assert", "node": "/root/GameManager", "property": "currency", "equals": 0},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_ascension_multiplier", "comment": "Should be 2.25 (1.5^2)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["magnet"], "comment": "Should be 0 after second ascension"},

    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "SILVER", "comment": "Collect a coin to verify boosted value"},
    {"type": "wait", "seconds": 0.5},
    {"type": "command", "name": "get-state", "node_path": "/root/GameManager", "property": "currency", "comment": "Should be 2 (int(1*2.25*1.0)=2)"},

    {"type": "screenshot", "filename": "double_asc_04_final.png"},
    {"type": "command", "name": "clear-coins"}
  ]
}
