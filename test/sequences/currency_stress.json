{
  "name": "Currency Stress Test",
  "description": "Edge case test for rapid currency changes, bomb deduction, and expensive purchases",
  "steps": [
    {"type": "wait", "seconds": 0.5, "comment": "Wait for game to stabilize"},
    {"type": "command", "name": "reset-session", "comment": "Reset to clean state"},
    {"type": "command", "name": "clear-coins", "comment": "Remove any falling coins"},
    {"type": "wait", "seconds": 0.2},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "add_currency", "args": [1000000], "comment": "Give 1,000,000 currency"},
    {"type": "wait", "seconds": 0.2},
    {"type": "assert", "node": "/root/GameManager", "property": "currency", "equals": 1000000},
    {"type": "screenshot", "filename": "stress_01_one_million.png"},
    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "BOMB", "comment": "Trigger bomb (lose 10%)"},
    {"type": "wait", "seconds": 1.0, "comment": "Wait for bomb to hit"},
    {"type": "assert", "node": "/root/GameManager", "property": "currency", "equals": 900000},
    {"type": "screenshot", "filename": "stress_02_after_bomb.png"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "add_currency", "args": [100000], "comment": "Add 100k more"},
    {"type": "wait", "seconds": 0.1},
    {"type": "assert", "node": "/root/GameManager", "property": "currency", "equals": 1000000},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "add_currency", "args": [-50000], "comment": "Deduct 50k"},
    {"type": "wait", "seconds": 0.1},
    {"type": "assert", "node": "/root/GameManager", "property": "currency", "equals": 950000},
    {"type": "screenshot", "filename": "stress_03_rapid_changes.png"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["spawn_rate"], "comment": "Buy spawn_rate level 1 (cost 10)"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["spawn_rate"], "comment": "Buy spawn_rate level 2 (cost ~11)"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["spawn_rate"], "comment": "Buy spawn_rate level 3 (cost ~13)"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["spawn_rate"], "comment": "Buy spawn_rate level 4 (cost ~15)"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["spawn_rate"], "comment": "Buy spawn_rate level 5 (cost ~17)"},
    {"type": "wait", "seconds": 0.2},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["spawn_rate"], "comment": "Verify level 5"},
    {"type": "screenshot", "filename": "stress_04_rapid_purchases.png"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["coin_value"], "comment": "Buy coin_value level 1 (cost 15)"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["coin_value"], "comment": "Level 2"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["coin_value"], "comment": "Level 3"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["coin_value"], "comment": "Level 4"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["coin_value"], "comment": "Level 5"},
    {"type": "wait", "seconds": 0.2},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["coin_value"], "comment": "Verify level 5"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["catcher_width"], "comment": "Buy catcher_width level 1 (cost 20)"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["catcher_width"], "comment": "Level 2"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["catcher_width"], "comment": "Level 3"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["catcher_width"], "comment": "Level 4"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["catcher_width"], "comment": "Level 5"},
    {"type": "wait", "seconds": 0.2},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["catcher_width"], "comment": "Verify level 5"},
    {"type": "screenshot", "filename": "stress_05_more_purchases.png"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["magnet"], "comment": "Buy magnet level 1 (cost 25)"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["magnet"], "comment": "Level 2"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["magnet"], "comment": "Level 3"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["magnet"], "comment": "Level 4"},
    {"type": "wait", "seconds": 0.05},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["magnet"], "comment": "Level 5"},
    {"type": "wait", "seconds": 0.2},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["magnet"], "comment": "Verify level 5"},
    {"type": "screenshot", "filename": "stress_06_final_purchases.png"},
    {"type": "command", "name": "get-state", "node_path": "/root/GameManager", "property": "currency", "comment": "Check final currency"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["spawn_rate"], "comment": "Verify all upgrades at level 5"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["coin_value"]},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["catcher_width"]},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["magnet"]},
    {"type": "command", "name": "spawn-coin-on-catcher", "coin_type": "BOMB", "comment": "Trigger another bomb"},
    {"type": "wait", "seconds": 1.0},
    {"type": "screenshot", "filename": "stress_07_second_bomb.png"},
    {"type": "command", "name": "get-state", "node_path": "/root/GameManager", "property": "currency", "comment": "Check currency after second bomb (should be 90% of previous)"},
    {"type": "command", "name": "clear-coins"}
  ]
}
