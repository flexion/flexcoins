{
  "name": "Magnet Upgrade Test",
  "description": "Test magnet upgrade increases radius and strength, verify coin attraction",
  "steps": [
    {"type": "wait", "seconds": 0.5, "comment": "Wait for game to stabilize"},
    {"type": "command", "name": "reset-session", "comment": "Reset to clean state"},
    {"type": "command", "name": "clear-coins", "comment": "Remove any falling coins"},
    {"type": "wait", "seconds": 0.2},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["magnet"], "comment": "Check initial magnet level (0)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_magnet_radius", "comment": "Check initial magnet radius (0)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_magnet_strength", "comment": "Check initial magnet strength (0)"},
    {"type": "screenshot", "filename": "magnet_01_level_0.png"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "add_currency", "args": [10000], "comment": "Give currency for upgrades"},
    {"type": "wait", "seconds": 0.2},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["magnet"], "comment": "Buy magnet level 1"},
    {"type": "wait", "seconds": 0.3},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["magnet"], "comment": "Verify level 1"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_magnet_radius", "comment": "Verify radius increased (80 + 30 = 110)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_magnet_strength", "comment": "Verify strength increased (100 + 40 = 140)"},
    {"type": "screenshot", "filename": "magnet_02_level_1.png"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["magnet"], "comment": "Buy magnet level 2"},
    {"type": "wait", "seconds": 0.2},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["magnet"], "comment": "Buy magnet level 3"},
    {"type": "wait", "seconds": 0.2},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["magnet"], "comment": "Buy magnet level 4"},
    {"type": "wait", "seconds": 0.2},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "try_purchase_upgrade", "args": ["magnet"], "comment": "Buy magnet level 5"},
    {"type": "wait", "seconds": 0.3},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["magnet"], "comment": "Verify level 5"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_magnet_radius", "comment": "Verify radius at level 5 (80 + 150 = 230)"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_magnet_strength", "comment": "Verify strength at level 5 (100 + 200 = 300)"},
    {"type": "screenshot", "filename": "magnet_03_level_5.png"},
    {"type": "command", "name": "spawn-coin", "coin_type": "SILVER", "x": 1000, "comment": "Spawn coin 80px left of catcher center (1080)"},
    {"type": "wait", "seconds": 0.5, "comment": "Wait for magnet to attract coin"},
    {"type": "command", "name": "get-active-coins", "comment": "Check if coin was attracted"},
    {"type": "screenshot", "filename": "magnet_04_attracted.png"},
    {"type": "wait", "seconds": 1.0, "comment": "Wait for coin collection"},
    {"type": "screenshot", "filename": "magnet_05_collected.png"},
    {"type": "command", "name": "spawn-coin", "coin_type": "SILVER", "x": 1160, "comment": "Spawn coin 80px right of catcher center"},
    {"type": "wait", "seconds": 0.5},
    {"type": "screenshot", "filename": "magnet_06_right_attracted.png"},
    {"type": "wait", "seconds": 1.0},
    {"type": "screenshot", "filename": "magnet_07_right_collected.png"},
    {"type": "command", "name": "clear-coins"}
  ]
}
