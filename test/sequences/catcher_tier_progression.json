{
  "name": "Catcher Tier Progression Test",
  "description": "Test catcher visual tiers at width levels 10, 20, 30 (wooden, chrome, rainbow)",
  "steps": [
    {"type": "wait", "seconds": 0.5, "comment": "Wait for game to stabilize"},
    {"type": "command", "name": "reset-session", "comment": "Reset to clean state"},
    {"type": "command", "name": "clear-coins", "comment": "Remove any falling coins"},
    {"type": "wait", "seconds": 0.2},
    {"type": "screenshot", "filename": "tier_01_level_0_blue.png", "comment": "Tier 0: default blue"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "add_currency", "args": [1000000], "comment": "Give currency for upgrades"},
    {"type": "wait", "seconds": 0.2},
    {"type": "command", "name": "set-upgrade-levels", "spawn_rate": 0, "coin_value": 0, "catcher_speed": 0, "catcher_width": 10, "magnet": 0, "comment": "Set catcher width to level 10"},
    {"type": "wait", "seconds": 0.5, "comment": "Wait for visual update"},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["catcher_width"], "comment": "Verify level 10"},
    {"type": "screenshot", "filename": "tier_02_level_10_wooden.png", "comment": "Tier 1: wooden brown with grain"},
    {"type": "command", "name": "set-upgrade-levels", "spawn_rate": 0, "coin_value": 0, "catcher_speed": 0, "catcher_width": 15, "magnet": 0, "comment": "Set to level 15 (still tier 1)"},
    {"type": "wait", "seconds": 0.5},
    {"type": "screenshot", "filename": "tier_03_level_15_wooden.png", "comment": "Still tier 1 wooden"},
    {"type": "command", "name": "set-upgrade-levels", "spawn_rate": 0, "coin_value": 0, "catcher_speed": 0, "catcher_width": 20, "magnet": 0, "comment": "Set to level 20"},
    {"type": "wait", "seconds": 0.5},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["catcher_width"], "comment": "Verify level 20"},
    {"type": "screenshot", "filename": "tier_04_level_20_chrome.png", "comment": "Tier 2: chrome/silver metallic with highlight"},
    {"type": "command", "name": "set-upgrade-levels", "spawn_rate": 0, "coin_value": 0, "catcher_speed": 0, "catcher_width": 25, "magnet": 0, "comment": "Set to level 25 (still tier 2)"},
    {"type": "wait", "seconds": 0.5},
    {"type": "screenshot", "filename": "tier_05_level_25_chrome.png", "comment": "Still tier 2 chrome"},
    {"type": "command", "name": "set-upgrade-levels", "spawn_rate": 0, "coin_value": 0, "catcher_speed": 0, "catcher_width": 30, "magnet": 0, "comment": "Set to level 30"},
    {"type": "wait", "seconds": 0.5},
    {"type": "command", "name": "run-method", "node_path": "/root/GameManager", "method": "get_upgrade_level", "args": ["catcher_width"], "comment": "Verify level 30"},
    {"type": "screenshot", "filename": "tier_06_level_30_rainbow.png", "comment": "Tier 3: rainbow animated (hue cycle)"},
    {"type": "wait", "seconds": 1.0, "comment": "Wait for rainbow animation to cycle"},
    {"type": "screenshot", "filename": "tier_07_level_30_rainbow_animated.png", "comment": "Rainbow mid-cycle"},
    {"type": "wait", "seconds": 1.0},
    {"type": "screenshot", "filename": "tier_08_level_30_rainbow_full_cycle.png", "comment": "Rainbow after full cycle"},
    {"type": "command", "name": "set-upgrade-levels", "spawn_rate": 0, "coin_value": 0, "catcher_speed": 0, "catcher_width": 40, "magnet": 0, "comment": "Set to level 40 (still tier 3)"},
    {"type": "wait", "seconds": 0.5},
    {"type": "screenshot", "filename": "tier_09_level_40_rainbow.png", "comment": "Level 40 still rainbow"},
    {"type": "command", "name": "clear-coins"}
  ]
}
